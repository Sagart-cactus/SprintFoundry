# SprintFoundry Environment Variables

# Required: Anthropic API key (used for orchestrator agent and default agent model)
SPRINTFOUNDRY_ANTHROPIC_KEY=sk-ant-xxxxxxxxxxxx

# Optional: OpenAI API key (if using OpenAI models for any agent)
# SPRINTFOUNDRY_OPENAI_KEY=sk-xxxxxxxxxxxx

# Optional: Google API key (if using Gemini models for any agent)
# SPRINTFOUNDRY_GOOGLE_KEY=xxxxxxxxxxxx

# Ticket source integrations
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxx
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# JIRA_API_TOKEN=xxxxxxxxxxxx

# Notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Execution mode: set to "true" to run agents in Docker containers
# SPRINTFOUNDRY_USE_CONTAINERS=false

# Logging level: debug | info | warn | error
# SPRINTFOUNDRY_LOG_LEVEL=info

# ----- Internal Ingestion API Hardening (optional overrides) -----
# Required when ingestion API is enabled:
# SPRINTFOUNDRY_INTERNAL_API_TOKEN=replace-with-random-long-token
# SPRINTFOUNDRY_DATABASE_URL=postgres://user:pass@host:5432/dbname
# Optional:
# SPRINTFOUNDRY_REDIS_URL=redis://localhost:6379
#
# Request size controls (bytes)
# SPRINTFOUNDRY_INGEST_EVENTS_MAX_BODY_BYTES=65536
# SPRINTFOUNDRY_INGEST_RUNS_MAX_BODY_BYTES=32768
# SPRINTFOUNDRY_INGEST_STEP_RESULTS_MAX_BODY_BYTES=65536
# SPRINTFOUNDRY_INGEST_LOGS_MAX_BODY_BYTES=131072
# SPRINTFOUNDRY_INGEST_EVENT_DATA_MAX_BYTES=49152
# SPRINTFOUNDRY_INGEST_STEP_RESULT_MAX_BYTES=49152
# SPRINTFOUNDRY_INGEST_LOG_CHUNK_MAX_BYTES=65536
#
# Rate limiting controls (per token, fixed window)
# SPRINTFOUNDRY_INGEST_RATE_LIMIT_WINDOW_MS=60000
# SPRINTFOUNDRY_INGEST_RATE_LIMIT_EVENTS_PER_WINDOW=240
# SPRINTFOUNDRY_INGEST_RATE_LIMIT_RUNS_PER_WINDOW=120
# SPRINTFOUNDRY_INGEST_RATE_LIMIT_STEP_RESULTS_PER_WINDOW=240
# SPRINTFOUNDRY_INGEST_RATE_LIMIT_LOGS_PER_WINDOW=360

# ----- OpenTelemetry / Metrics (optional) -----
# Set SPRINTFOUNDRY_OTEL_ENABLED=1 to enable metrics from the orchestration
# service AND from Claude Code and Codex CLI agents.
# All metrics are forwarded to an OTLP-compatible collector.
#
# Quick start (runs OTel Collector + Prometheus + Grafana):
#   docker compose -f docker-compose.otel.yml up -d
#
# Then browse to:
#   Prometheus:  http://localhost:9090
#   Grafana:     http://localhost:3000  (admin / sprintfoundry)
#   Raw scrape:  http://localhost:8889/metrics
#
# SPRINTFOUNDRY_OTEL_ENABLED=1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # HTTP (default)
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf           # http/protobuf | grpc
