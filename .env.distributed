# SprintFoundry distributed local mode (host CLI + docker-compose.distributed.yml)

# Event sink target used by SprintFoundry CLI (host machine)
SPRINTFOUNDRY_EVENT_SINK_URL=http://localhost:3001/events
SPRINTFOUNDRY_INTERNAL_API_TOKEN=dev-token

# Optional host-side URLs (used only when running event-api/monitor outside compose)
SPRINTFOUNDRY_DATABASE_URL=postgres://sf:sf@localhost:5432/sprintfoundry
SPRINTFOUNDRY_REDIS_URL=redis://localhost:6379

# Container-side URLs used by docker-compose.distributed.yml services
SPRINTFOUNDRY_COMPOSE_DATABASE_URL=postgres://sf:sf@postgres:5432/sprintfoundry
SPRINTFOUNDRY_COMPOSE_REDIS_URL=redis://redis:6379

# Compose bootstrap for local postgres container
SPRINTFOUNDRY_POSTGRES_USER=sf
SPRINTFOUNDRY_POSTGRES_PASSWORD=sf
SPRINTFOUNDRY_POSTGRES_DB=sprintfoundry
